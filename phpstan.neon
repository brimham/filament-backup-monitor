includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    paths:
        - src
    # The BackupRun model lives in the core package; point Larastan at its
    # vendored migration so backup_runs attributes (size_in_bytes, message,
    # created_at, …) resolve from the schema without @property docblocks.
    databaseMigrationsPath:
        - vendor/brimham/backup-monitor/database/migrations
