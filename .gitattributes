# Keep `composer require` downloads lean — exclude dev-only paths and the
# screenshots from the release tarball. They stay in the GitHub repo (so the
# README still renders) but are not shipped to installs.
/.github        export-ignore
/art            export-ignore
/tests          export-ignore
.gitattributes  export-ignore
.gitignore      export-ignore
phpstan.neon    export-ignore
phpunit.xml     export-ignore
