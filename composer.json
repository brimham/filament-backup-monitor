{
    "name": "brimham/filament-backup-monitor",
    "description": "Filament panel for brimham/backup-monitor — run history and last-backup-per-destination health for spatie/laravel-backup.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "backup",
        "monitoring",
        "spatie",
        "backup-monitor"
    ],
    "require": {
        "php": "^8.3",
        "brimham/backup-monitor": "^0.1.1",
        "filament/filament": "^3.0 || ^4.0 || ^5.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "laravel/pint": "^1.29",
        "larastan/larastan": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Brimham\\FilamentBackupMonitor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brimham\\FilamentBackupMonitor\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Brimham\\FilamentBackupMonitor\\FilamentBackupMonitorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
